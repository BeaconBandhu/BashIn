{
  "manifest_version": 3,
  "name": "BashIn Bridge",
  "version": "1.0.0",
  "description": "Lets the BashIn voice agent drive Swiggy Instamart and Google Calendar inside your own logged-in Chrome.",
  "permissions": ["tabs", "alarms"],
  "host_permissions": ["*://*.swiggy.com/*", "*://calendar.google.com/*"],
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": ["*://*.swiggy.com/*", "*://calendar.google.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
